{
  "name": "bis-tech-extension",
  "version": "1.0.10",
  "displayName": "Bis-Tech extension",
  "author": "giuxtaposition",
  "description": "A web extension to make life easier for bis-tech team",
  "scripts": {
    "build": "vite build",
    "build-firefox": "EXTENSION=firefox pnpm build",
    "watch": "vite build --watch --mode development --minify false",
    "watch-firefox": "EXTENSION=firefox pnpm watch",
    "dev": "vite",
    "dev-firefox": "EXTENSION=firefox pnpm dev",
    "serve:firefox": "web-ext run --start-url \"about:debugging#/runtime/this-firefox\"  --source-dir ./dist/",
    "serve:chrome": "web-ext run -t chromium --start-url \"https://calc-dev.vitesicure.it\" --source-dir ./dist/",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "storybook": "ENVIRONMENT=storybook storybook dev -p 6006",
    "build-storybook": "ENVIRONMENT=storybook storybook build",
    "pack:crx": "crx pack dist -o ./extension/extension.crx",
    "pack:xpi": "WEB_EXT_ARTIFACTS_DIR=./extension/ web-ext build --source-dir ./dist --filename extension.xpi --overwrite-dest",
    "pack:zip": "rimraf ./extension/extension.zip && jszip-cli add dist/* -o ./extension/extension.zip",
    "test": "ENVIRONMENT=test vitest run",
    "coverage": "ENVIRONMENT=test vitest run --coverage"
  },
  "license": "MIT",
  "devDependencies": {
    "@ffflorian/jszip-cli": "^3.16.1",
    "@samrum/vite-plugin-web-extension": "^5.1.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^10.3.6",
    "@storybook/blocks": "^8.6.14",
    "@storybook/builder-vite": "^10.3.6",
    "@storybook/svelte": "^10.3.6",
    "@storybook/svelte-vite": "^10.3.6",
    "@storybook/testing-library": "^0.2.2",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/chrome": "^0.1.42",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.2",
    "@types/webextension-polyfill": "^0.12.5",
    "crx": "^5.0.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rimraf": "^6.1.3",
    "sass": "^1.99.0",
    "storybook": "^10.3.6",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "svelte-preprocess": "^6.0.3",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "~8.0.11",
    "vite-plugin-checker": "^0.13.0",
    "vitest": "^4.1.5",
    "vitest-dom": "^0.1.1",
    "web-ext": "^10.1.0"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "webext-options-sync": "^4.3.0",
    "webextension-polyfill": "^0.12.0"
  },
  "type": "module"
}
